  <script>
  // --- Demo progress (edit starting values here) ---
  let pledged = 3,200; // AUD
  const goal = 8000;
  const bar = document.getElementById('treasury-bar'); // was 'progress-bar'
  const pledgedLabel = document.getElementById('treasury-pledged'); // optional label that exists elsewhere

  function renderProgress(){
    if (bar){
      const pct = Math.max(0, Math.min(100, (pledged/goal)*100));
      bar.style.width = pct.toFixed(2) + '%';
    }
    const statTreasury = document.getElementById('stat-treasury');
    if (statTreasury) statTreasury.textContent = `$${pledged.toLocaleString()}`;
    const statGoal = document.getElementById('stat-goal');
    if (statGoal) statGoal.textContent = `$${goal.toLocaleString()}`;
    if (pledgedLabel) pledgedLabel.textContent = `$${pledged.toLocaleString()} pledged · Goal: $${goal.toLocaleString()}`;
  }
  renderProgress();
</script>


  <script>
  // --- Preload overlay control ---
  (function(){
    const overlay = document.getElementById('preload');
    if(!overlay) return;

    // Minimum display time so the line is actually seen
    const MIN_MS = 4000;

    const start = performance.now();
    function dismiss(){
      const elapsed = performance.now() - start;
      const wait = Math.max(0, MIN_MS - elapsed);
      setTimeout(() => {
        overlay.classList.add('fade-out');
        overlay.addEventListener('animationend', () => overlay.remove(), { once: true });
      }, wait);
    }

    // Dismiss when DOM ready and after images try to resolve
    if (document.readyState === 'complete') {
      dismiss();
    } else {
      window.addEventListener('load', dismiss);
      // Safety: if on slow connections, dismiss anyway after 3.5s
      setTimeout(dismiss, 3500);
    }
  })();
  
</script>

<script>
  // Fallback: hide preload after 5 seconds if it's still visible
  setTimeout(() => {
    const preload = document.getElementById('preload');
    if (preload && !preload.classList.contains('fade-out')) {
      preload.classList.add('fade-out');
      // optional: fully remove it from DOM after fade-out ends
      setTimeout(() => preload.remove(), 500);
    }
  }, 5000);
</script>

<script>
(function() {
  const details = document.getElementById('witnessRoll');
  if(!details) return;

  details.addEventListener('toggle', function() {
    if (!details.open) return;

    fetch('witnesses.json?' + Date.now()) // cache-bust
      .then(response => response.json())
      .then(data => {
        const ul = document.getElementById('witnessList');
        if (!ul) return;
        ul.innerHTML = '';
        data.forEach(entry => {
          const li = document.createElement('li');
          li.textContent = `#${entry.number} — ${entry.name} (${entry.locality}) — ${entry.date}`;
          ul.appendChild(li);
        });
        const content = document.getElementById('witnessContent');
        if (content) content.style.display = 'block';
      })
      .catch(err => {
        console.error(err);
      });
  });
})();
</script>
<script>
(function () {
  const form = document.getElementById('join-form');
  const msg  = document.getElementById('form-message');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();               // <-- stops the page navigation
    msg.textContent = 'Submitting…';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),     // send exactly what’s in the form
        headers: { 'Accept': 'application/json' } // ask Formspree for JSON
      });

      if (!res.ok) throw new Error('Network/endpoint error');
      // Optional: you can check await res.json() here if you want
      msg.textContent = 'Thank you — your name has been received.';
      form.reset();                   // keep or remove if you want fields to remain
    } catch (err) {
      msg.textContent = 'Could not submit right now. Please try again shortly.';
    }
  });
})();
</script>


